# Mapbox (public — used by AddressAutocomplete)
NEXT_PUBLIC_MAPBOX_API_KEY=pk.your-mapbox-public-token

# Hetzner Object Storage (S3-compatible)
# To switch to AWS S3: remove S3_ENDPOINT, remove forcePathStyle from src/lib/s3.ts, update region
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_REGION=fsn1
S3_BUCKET=patrik-assets
S3_PUBLIC_BASE=https://patrik-assets.fsn1.your-objectstorage.com
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# MongoDB — warranty submission persistence
MONGODB_URI="mongodb://user:password@host:27017/patrik?authSource=patrik"

# Google Sheets — warranty submission log
# Create a GCP service account, enable the Sheets API, download a JSON key,
# share the target sheet with the service account email (Editor access).
GOOGLE_SA_CLIENT_EMAIL=warranty-form-writer@your-project.iam.gserviceaccount.com
# Paste the private_key from the service account JSON. Keep the \n escapes —
# the app calls replace(/\\n/g, "\n") at read time.
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_TAB=Submissions

# Public base URL — used to build the receipt-page hyperlink in the Google Sheet
BASE_URL=https://your-deployment-url.example.com

# SMTP — transactional email (customer confirmation + admin notification)
# Any standard SMTP host works (your email hosting provider will give you these).
# Port 465 = implicit TLS (SMTPS); port 587 = STARTTLS. The app derives "secure"
# from the port automatically. Admin recipients are configured in
# config/notifications.json (not here).
SMTP_HOST=smtp.your-host.com
SMTP_PORT=465
SMTP_USER=noreply@patrikinternational.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="Patrik Warranty <noreply@patrikinternational.com>"

# Google Analytics (optional; leave unset to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry — error tracking (optional; leave unset to disable)
# DSN is required for the SDK to send events. The NEXT_PUBLIC_ copy is used by
# the browser bundle; the un-prefixed copy is used server-side. They normally
# point at the same DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Tags events so prod/staging are distinguishable in Sentry. Defaults to NODE_ENV.
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Build-time only — used by withSentryConfig in next.config.ts to upload source
# maps. Safe to leave blank locally; release builds will skip the upload step.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
